{
  "permissions": {
    "allow": [
      "Bash(obsidian-open *)",
      "Bash(relative-dates:*)",
      "Bash(transcribe:*)",
      "Glob(~/_/main/**/todo.md)",
      "Read(~/_/main/**/todo.md)",
      "Read(~/_/main/*/todo.md)",
      "Glob(~/_/main/**/contact.md)",
      "Read(~/_/main/**/contact.md)",
      "Read(~/_/main/*/contact.md)"
    ]
  },
  "model": "opus",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "lemonaid-claude-statusline write-last-message-time"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "lemonaid claude notify"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "lemonaid claude notify"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "lemonaid-claude-statusline"
  },
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "."
    ]
  }
}
