{
  // Editor:  Appearance
  "workbench.colorTheme": "Minimal",
  "editor.fontFamily": "'Fira Code', Menlo, Monaco, 'Courier New', monospace",
  "editor.fontLigatures": true,
  "editor.fontVariations": false,
  "editor.cursorStyle": "line",
  "editor.lineNumbers": "relative",
  "editor.minimap.enabled": false,
  "editor.guides.bracketPairs": true,
  "editor.wordWrap": "on",
  "editor.tokenColorCustomizations": {
    "textMateRules": [
      {
        "scope": ["keyword.checkbox-todo"],
        "settings": {
          "foreground": "#ac2814e6",
          "fontStyle": "bold",
        },
      },
      {
        "scope": ["keyword.event"],
        "settings": {
          "foreground": "#6E3500",
          "fontStyle": "bold",
        },
      },
      {
        "scope": ["keyword.checkbox-malformed"],
        "settings": {
          "foreground": "#b041b0",
          "fontStyle": "bold",
        },
      },
      {
        "scope": ["keyword.checkbox-right_now"],
        "settings": {
          "foreground": "#0f5ec4",
          "fontStyle": "bold",
        },
      },
      {
        "scope": ["keyword.checkbox-next"],
        "settings": {
          "foreground": "#1e47cf",
          "fontStyle": "bold",
        },
      },
      {
        "scope": ["keyword.checkbox-migrated"],
        "settings": {
          "foreground": "#7953c5",
          "fontStyle": "bold",
        },
      },
      {
        "scope": ["keyword.checkbox-waiting"],
        "settings": {
          "foreground": "#FFA500",
          "fontStyle": "bold",
        },
      },
      {
        "scope": ["keyword.checkbox-done"],
        "settings": {
          "foreground": "#3cbf09",
          "fontStyle": "bold",
        },
      },
      {
        "scope": ["keyword.checkbox-strikethrough"],
        "settings": {
          "foreground": "#172017",
          "fontStyle": "bold",
        },
      },
      {
        "scope": ["keyword.strikethrough-text"],
        "settings": {
          "fontStyle": "italic",
          "foreground": "#00000070",
        },
      },
      {
        "scope": ["keyword.bullet"],
        "settings": {
          "fontStyle": "bold",
        },
      },
    ],
  },
  "workbench.colorCustomizations": {
    // "diffEditor.removedTextBackground": "#7d062c",
    // "diffEditor.insertedTextBackground": "#3d5c0a",
    // "diffEditor.removedLineBackground": "#430017",
    // "diffEditor.insertedLineBackground": "#243c04",
    // "diffEditorOverview.insertedForeground": "#50c423", // "#192c00",
    // "diffEditorOverview.removedForeground": "#d10a50" // "#450017",
  },

  // Editor:  Behavior
  "editor.tabSize": 2,
  "editor.detectIndentation": false,
  "editor.formatOnSave": true,
  "editor.inlineSuggest.enabled": true,
  "editor.wordSeparators": "/\\()\"':,.;<>~!@#$%^&*|+=[]{}`?-",
  "editor.codeActionsOnSave": {
    "source.fixAll": "explicit",
  },

  // Workbench:  Layout
  "workbench.panel.defaultLocation": "right",
  "workbench.editor.openSideBySideDirection": "right",
  "workbench.editor.enablePreview": false,
  "workbench.editorAssociations": {
    "*.ipynb": "jupyter.notebook.ipynb",
  },
  "explorer.confirmDragAndDrop": false,

  // Files
  "files.trimTrailingWhitespace": true,
  "files.associations": {
    "myLambda.sql": "rsql",
  },

  // Terminal
  "terminal.external.osxExec": "iTerm2.app",
  "terminal.integrated.macOptionIsMeta": true,

  // Vim
  "vim.useSystemClipboard": true,
  "vim.textwidth": 105,
  "vim.easymotion": true,
  "vim.insertModeKeyBindings": [
    {
      "before": ["j", "j"],
      "after": ["<Esc>"],
    },
    {
      "before": ["<C-c>"],
      "after": ["<Enter>"],
    },
  ],
  "vim.normalModeKeyBindings": [
    {
      "before": ["<C-j>"],
      "commands": ["editor.action.moveLinesDownAction"],
    },
    {
      "before": ["<C-k>"],
      "commands": ["editor.action.moveLinesUpAction"],
    },
  ],
  "vim.visualModeKeyBindings": [
    {
      "before": ["<C-j>"],
      "commands": ["editor.action.moveLinesDownAction"],
    },
    {
      "before": ["<C-k>"],
      "commands": ["editor.action.moveLinesUpAction"],
    },
  ],
  "vim.visualModeKeyBindingsNonRecursive": [],

  // Language-specific overrides
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[jsonc]": {
    "editor.defaultFormatter": "rvest.vs-code-prettier-eslint",
  },
  "[javascript]": {
    "editor.defaultFormatter": "rvest.vs-code-prettier-eslint",
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "rvest.vs-code-prettier-eslint",
  },
  "[markdown]": {
    "editor.defaultFormatter": "DavidAnson.vscode-markdownlint",
  },
  "[python]": {
    "breadcrumbs.showClasses": true,
    "editor.tabSize": 4,
  },
  "[dockercompose]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 2,
    "editor.autoIndent": "advanced",
    "editor.quickSuggestions": {
      "other": true,
      "comments": false,
      "strings": true,
    },
    "editor.defaultFormatter": "redhat.vscode-yaml",
  },
  "[github-actions-workflow]": {
    "editor.defaultFormatter": "redhat.vscode-yaml",
  },
  "javascript.updateImportsOnFileMove.enabled": "always",
  "typescript.updateImportsOnFileMove.enabled": "always",
  "json.schemas": [
    {
      "fileMatch": ["*.json", "*.jsonc"],
      "schema": {
        "allowTrailingCommas": true
      }
    }
  ],

  // Formatters & Linters
  "prettier.useEditorConfig": false,
  "eslint.format.enable": true,
  "beautify.config": "",
  // "ruff.configurationPreference": "filesystemFirst",

  // Git & GitHub
  "git.autofetch": true,
  "git.blame.editorDecoration.enabled": false,
  "githubPullRequests.pullBranch": "never",
  "liveshare.authenticationProvider": "GitHub",

  // Extensions
  "github.copilot.enable": {
    "*": true,
    "plaintext": false,
    "markdown": false,
    "scminput": false,
    "yaml": false,
    "python": false,
  },
  "github.copilot.editor.enableAutoCompletions": true,
  "gitlens.ai.model": "gitkraken",
  "gitlens.ai.gitkraken.model": "gemini:gemini-2.5-flash",
  // "github.copilot.inlineSuggest.enable": false,
  "gitlens.views.branches.branches.layout": "list",
  "plantuml.render": "PlantUMLServer",
  "plantuml.server": "http://localhost:8888",
  "elixirLS.projectDir": "chat_server",
  "svg.preview.mode": "svg",
  "csv.enabled": false,
  "todomd.activatePattern": "**/{z.notes.todo,todo}.md",
  "todo.file.include": [
    "**/TODO",
    "**/TODOS",
    "**/*.TODO",
    "**/*.TODOS",
    "**/*.todo",
    "**/*.todos",
    "**/*.task",
    "**/*.tasks",
    "**/*.taskpaper",
    "**/todolist.txt",
    "**/todo.md",
  ],
  "cSpell.userWords": [
    "abfss",
    "ADLS",
    "CHECKMARK",
    "cpus",
    "Datavant",
    "Everly",
    "fqns",
    "incrementer",
    "pyprojects",
    "qurplemort",
    "relpaths",
    "thds",
    "thunking",
    "Trilliant"
  ],
  "docker.extension.enableComposeLanguageServer": false,
  "claudeCode.preferredLocation": "sidebar",
  "claudeCode.useTerminal": true,
  "claudeCode.useCtrlEnterToSend": true,

  // Python
  "python.analysis.importFormat": "relative",
  "python.analysis.nodeExecutable": "~/.local/share/mise/installs/node/24/bin/node",

  // Version control
  "extensions.autoUpdate": false,
  "update.mode": "manual",

  // Misc
  "php.validate.executablePath": "",
  "http.proxyStrictSSL": false,
  "chat.disableAIFeatures": true,
  "yaml.disableSchemaDetection": [
    "**/.github/workflows/*.yml",
    "**/.github/workflows/*.yaml",
    "**/.gitea/workflows/*.yml",
    "**/.gitea/workflows/*.yaml",
    "**/.forgejo/workflows/*.yml",
    "**/.forgejo/workflows/*.yaml"
  ]
}
