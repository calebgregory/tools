{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Markdown Checkboxes",
  "injectionSelector": "L:meta.paragraph.markdown",
  "scopeName": "source.checkboxes.md",
  "patterns": [{ "include": "#checkboxes" }],
  "repository": {
    "checkboxes": {
      "patterns": [
        {
          "match": "(\\[ \\])(?=\\s)",
          "captures": {
            "1": { "name": "keyword.checkbox-todo.org" }
          }
        },
        {
          "match": "(\\[\\])(?=\\s)",
          "captures": {
            "1": { "name": "keyword.checkbox-malformed.org" }
          }
        },
        {
          "match": "(\\[[Xx]\\])(?=\\s)",
          "captures": {
            "1": { "name": "keyword.checkbox-done.org" }
          }
        },
        {
          "match": "(\\[>\\])(?=\\s)",
          "captures": {
            "1": { "name": "keyword.checkbox-next.org" }
          }
        },
        {
          "match": "(\\[<\\])(?=\\s)",
          "captures": {
            "1": { "name": "keyword.checkbox-migrated.org" }
          }
        },
        {
          "match": "(\\[/\\])(?=\\s)",
          "captures": {
            "1": { "name": "keyword.checkbox-right_now.org" }
          }
        },
        {
          "match": "(\\[[Oo]\\])(?=\\s)",
          "captures": {
            "1": { "name": "keyword.checkbox-waiting.org" }
          }
        },
        {
          "match": "(\\[-\\])\\s+(.*$)",
          "captures": {
            "1": { "name": "keyword.checkbox-strikethrough.org" },
            "2": { "name": "keyword.strikethrough-text.org" }
          }
        },
        {
          "match": "(\\[[Vv]\\])(?=\\s)",
          "captures": {
            "1": { "name": "keyword.checkbox-done.org" }
          }
        }
      ]
    }
  }
}
